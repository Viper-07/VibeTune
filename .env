# Dev server: use https:// in the address bar (not http://). Brave may hide "https://" when secure.
HTTPS=true
PORT=3001
SSL_CRT_FILE=certs/localhost.crt
SSL_KEY_FILE=certs/localhost.key

# Mood analysis (https://console.anthropic.com/). Prefer .env.local for secrets — it is gitignored by CRA.
REACT_APP_ANTHROPIC_API_KEY=
